{
  "name": "noob-js",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:docs": "tsc -b && vite build --config vite.config.docs.ts",
    "watch:docs": "vite build --watch --config vite.config.docs.dev.ts",
    "build:package": "tsc -b && vite build --config vite.config.package.ts",
    "watch:package": "vite build --watch --config vite.config.package.dev.ts",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "npm run lint -- --fix",
    "format": "prettier -w .",
    "format:check": "prettier -c .",
    "test": "vitest"
  },
  "dependencies": {
    "@xyflow/react": "^12.10.0",
    "elkjs": "^0.11.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@eslint/js": "^9.39.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/babel__core": "^7.20.5",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/eslint-plugin": "^1.6.16",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "prettier": "^3.7.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.46.4",
    "vite": "^8",
    "vitest": "^4.1.5",
    "web-worker": "^1.5.0"
  }
}
