<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <title>noob viewer - {{ tube_id }}</title>
    <script src="/static/js/noob-js.js"></script>
    <link rel="stylesheet" type="text/css" href="/static/css/noob-js.css">
  </head>
  <body>
    <div id="root"></div>
    <script>
      let wss;
      wss = new WebSocket('/spec/{{ tube_id }}');
      wss.addEventListener('message', (event) => {
        let spec = JSON.parse(event.data);
        renderPipeline("#root", spec);
      })

    </script>
  </body>
</html>
